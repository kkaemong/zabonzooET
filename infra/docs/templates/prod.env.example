BACKEND_IMAGE=registry.example.com/monet/backend:latest
FRONTEND_IMAGE=registry.example.com/monet/frontend:latest

POSTGRES_HOST=postgres
POSTGRES_PORT=5432

POSTGRES_DB=monet
POSTGRES_USER=monet
POSTGRES_PASSWORD=change_me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/monet
SPRING_DATASOURCE_USERNAME=monet
SPRING_DATASOURCE_PASSWORD=change_me

SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
