#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

PATTERN="${JIRA_KEY_PATTERN:-[A-Z][A-Z0-9]+-[0-9]+}"

if grep -Eq "$PATTERN" "$MSG_FILE"; then
  exit 0
fi

echo "[jira-hook] Commit message must include a Jira issue key (ex: A507-123)."
echo "[jira-hook] Current message:"
sed -n '1,3p' "$MSG_FILE"
exit 1
