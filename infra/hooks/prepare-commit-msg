#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
SOURCE="${2:-}"

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

# Skip auto-generated commit message sources.
case "$SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

PATTERN="${JIRA_KEY_PATTERN:-[A-Z][A-Z0-9]+-[0-9]+}"

if grep -Eq "$PATTERN" "$MSG_FILE"; then
  exit 0
fi

BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
ISSUE_KEY="$(printf '%s' "$BRANCH" | grep -oE "$PATTERN" | head -n1 || true)"

if [ -z "$ISSUE_KEY" ]; then
  exit 0
fi

FIRST_LINE="$(head -n1 "$MSG_FILE")"
if [ -n "$FIRST_LINE" ]; then
  # 첫 번째 줄 끝에 (이슈키) 추가
  sed -i "1s/$/($ISSUE_KEY)/" "$MSG_FILE"
else
  printf '(%s)\n' "$ISSUE_KEY" > "$MSG_FILE"
fi
